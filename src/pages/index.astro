---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import logo from '../assets/logo.png';

const horarios = {
	dias: 'Miércoles a Domingo',
	horas: '9:00 AM — 4:00 PM',
	cerrado: 'Lunes y Martes',
};

const tacos = [
	{
		name: 'Taco de chamorro suave',
		price: 25,
		detail: 'Chamorro jugoso estilo barbacoa, tortilla hecha a mano.',
	},
	{
		name: 'Taco de chamorro dorado',
		price: 20,
		detail: 'Chamorro doradito estilo barbacoa Jalisco, tortilla delgada.',
	},
];

const tortas = [
	{
		name: 'Torta ahogada de chamorro',
		price: 80,
		detail: 'Torta rellena de chamorro y bañada en el mismo consomé del chamorro.',
	},
];

const estrellaIncluye = [
	'Consomé de la casa (de cortesía)',
	'Cebolla morada curtida',
	'Salsas',
	'Limón',
	'Tortillas recién hechas',
];

const bebidas = [
	{ name: 'Aguas frescas', price: '25 / 45', note: 'chica / grande' },
	{ name: 'Refrescos', price: 30 },
	{ name: 'Agua natural', price: 18 },
];

const combos = [
	{ name: 'Combo tacos', includes: '3 tacos dorados + agua chica o refresco', price: 85 },
	{ name: 'Combo torta', includes: 'torta + consomé + refresco', price: 110 },
	{ name: 'Combo chamorro', includes: 'chamorro + agua chica o refresco', price: 140 },
];

// TODO: re-enable galería cuando tengamos fotos reales del local y los platos.
// const galeria = [
// 	{ tag: 'Plato estrella', label: 'Chamorro en consomé', hue: '--terracota' },
// 	{ tag: 'Tacos', label: 'Dorados, recién hechos', hue: '--consome' },
// 	{ tag: 'Torta', label: 'Torta ahogada', hue: '--terracota-hondo' },
// 	{ tag: 'El lugar', label: 'Barrio bien hecho', hue: '--cafe' },
// ];

const direccion = {
	calle: 'Isla Cozumel 2670',
	colonia: 'Col. Jardines de la Cruz',
	ciudad: 'Guadalajara, Jal.',
	maps: 'https://www.google.com/maps/search/?api=1&query=Isla+Cozumel+2670+Jardines+de+la+Cruz+Guadalajara',
};

// Croquis grid — blocks drawn programmatically so the diagonal grid stays
// coherent. The rotation is applied at (300, 200) so the Isla Cozumel ×
// Isla Trinidad intersection lands exactly at the pin.
const mapaBlocks: { x: number; y: number }[] = [];
for (let row = -2; row <= 5; row++) {
	for (let col = -2; col <= 7; col++) {
		mapaBlocks.push({ x: col * 100 + 5, y: row * 100 + 5 });
	}
}
// A few nearby POI dots (restaurants/points) in inner coord space
const mapaPoi = [
	{ x: 140, y: 255 },
	{ x: 435, y: 155 },
	{ x: 540, y: 355 },
	{ x: 155, y: 440 },
];
---

<Layout>
	<!-- =========================================================
		NAV
	========================================================== -->
	<header class="nav">
		<a href="/" class="nav-brand" aria-label="Distrito Chamorro — inicio">
			<Image src={logo} alt="Distrito Chamorro" widths={[140, 240]} sizes="110px" class="nav-logo" />
		</a>
		<nav class="nav-links" aria-label="Secciones del menú">
			<a href="#menu">Menú</a>
			<a href="#horarios">Horarios</a>
			<a href="#lugar">Lugar</a>
			{/* TODO: re-enable WhatsApp "Pedir" CTA cuando tengamos el número real.
			<a
				href="https://wa.me/523312000000?text=Hola%2C%20quiero%20pedir%20chamorro"
				class="nav-cta"
				target="_blank"
				rel="noopener"
			>
				<svg viewBox="0 0 20 20" aria-hidden="true" class="nav-cta-icon">
					<path fill="currentColor" d="M10 0a10 10 0 0 0-8.5 15.2L0 20l4.9-1.4A10 10 0 1 0 10 0zm5.4 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.6-.6a11 11 0 0 1-4.3-3.8c-.3-.5-.9-1.4-.9-2.7S5.6 6 5.8 5.8c.2-.2.5-.3.6-.3h.5c.1 0 .3 0 .5.3l.6 1.5c.1.2.1.3 0 .4l-.3.4-.3.3c-.1.1-.2.2-.1.4l1.1 1.7c.6.8 1.2 1.2 1.8 1.5.3.1.5.1.7-.1l.6-.7c.2-.2.3-.2.5-.1l1.5.7c.3.1.4.2.5.3.1.2.1.8-.1 1.3z"/>
				</svg>
				Pedir
			</a>
			*/}
		</nav>
	</header>

	<main>
		<!-- =========================================================
			HERO
		========================================================== -->
		<section class="hero" aria-labelledby="hero-heading">
			<div class="hero-inner">
				<div class="hero-copy">
					<div class="hero-eyebrow">
						<span class="hero-pin">GDL</span>
						<span>Chamorrería · Cocina tapatía</span>
					</div>

					<h1 id="hero-heading" class="hero-title">
						<span class="hero-word hero-word-1">Chamorro</span>
						<span class="hero-word hero-word-2">
							que <em>empodera</em>
						</span>
					</h1>

					<p class="hero-sub">
						Tacos, tortas y chamorro en consomé.<br />
						Hecho en Guadalajara.
					</p>

					<div class="hero-ctas">
						<a href="#menu" class="cta cta-primary">
							Ver menú
							<svg class="cta-arrow" viewBox="0 0 26 12" aria-hidden="true">
								<path d="M0 6 H23 M17 1 L23 6 L17 11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" />
							</svg>
						</a>
						<a href="#lugar" class="cta cta-ghost">Cómo llegar</a>
					</div>

					<ul class="hero-tags" aria-label="Principios">
						<li>Consomé potente</li>
						<li><span aria-hidden="true">·</span></li>
						<li>Tortilla recién hecha</li>
						<li><span aria-hidden="true">·</span></li>
						<li>Barro de Tonalá</li>
					</ul>
				</div>

				<aside class="hero-visual" aria-hidden="true">
					<!-- Stylized chamorro-en-consomé illustration — brand-aligned placeholder -->
					<div class="plato">
						<div class="plato-frame">
							<svg viewBox="0 0 400 400" class="plato-svg">
								<defs>
									<radialGradient id="caldo" cx="50%" cy="42%" r="50%">
										<stop offset="0%" stop-color="#C9742A" />
										<stop offset="55%" stop-color="#A8321E" />
										<stop offset="100%" stop-color="#6B2C19" />
									</radialGradient>
									<radialGradient id="brillo" cx="40%" cy="35%" r="30%">
										<stop offset="0%" stop-color="rgba(255,230,180,0.55)" />
										<stop offset="100%" stop-color="rgba(255,230,180,0)" />
									</radialGradient>
									<pattern id="barro-rim" width="8" height="8" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
										<rect width="8" height="8" fill="#3a1e13" />
										<line x1="0" y1="0" x2="0" y2="8" stroke="#2B1A14" stroke-width="1.5" />
									</pattern>
								</defs>

								<!-- steam -->
								<g class="vapor" opacity="0.55">
									<path d="M140 40 Q155 70 140 105 Q125 135 145 170" fill="none" stroke="#F2E6D8" stroke-width="3" stroke-linecap="round" opacity="0.7" />
									<path d="M200 20 Q215 55 198 95 Q182 130 208 170" fill="none" stroke="#F2E6D8" stroke-width="3" stroke-linecap="round" opacity="0.9" />
									<path d="M265 40 Q250 75 268 110 Q285 145 260 175" fill="none" stroke="#F2E6D8" stroke-width="3" stroke-linecap="round" opacity="0.7" />
								</g>

								<!-- plate base shadow -->
								<ellipse cx="200" cy="340" rx="170" ry="18" fill="rgba(43, 26, 20, 0.35)" />

								<!-- outer rim (barro) -->
								<ellipse cx="200" cy="250" rx="175" ry="95" fill="#3A1E13" />
								<ellipse cx="200" cy="246" rx="170" ry="90" fill="#4A2618" />
								<ellipse cx="200" cy="244" rx="165" ry="86" fill="url(#barro-rim)" opacity="0.4" />

								<!-- inner bowl -->
								<ellipse cx="200" cy="240" rx="148" ry="72" fill="#2B1A14" />

								<!-- broth -->
								<ellipse cx="200" cy="232" rx="140" ry="62" fill="url(#caldo)" />

								<!-- chamorro piece -->
								<g transform="translate(145, 190)">
									<ellipse cx="55" cy="45" rx="56" ry="32" fill="#6B2C19" />
									<ellipse cx="55" cy="40" rx="52" ry="28" fill="#8C3A21" />
									<ellipse cx="55" cy="36" rx="44" ry="22" fill="#A8321E" />
									<!-- bone -->
									<rect x="92" y="30" width="30" height="9" rx="4" fill="#F2E6D8" />
									<circle cx="120" cy="30" r="6" fill="#F2E6D8" />
									<circle cx="120" cy="39" r="6" fill="#F2E6D8" />
									<!-- shine -->
									<ellipse cx="45" cy="28" rx="20" ry="5" fill="rgba(255,220,170,0.4)" />
								</g>

								<!-- aromatics floating -->
								<circle cx="90" cy="220" r="4" fill="#4E6B3A" opacity="0.8" /> <!-- cilantro -->
								<circle cx="95" cy="226" r="3.5" fill="#4E6B3A" opacity="0.7" />
								<circle cx="310" cy="235" r="4" fill="#4E6B3A" opacity="0.7" />
								<circle cx="305" cy="241" r="3" fill="#4E6B3A" opacity="0.8" />
								<!-- onion dice -->
								<rect x="110" y="252" width="5" height="5" fill="#F2E6D8" opacity="0.9" />
								<rect x="290" y="260" width="5" height="5" fill="#F2E6D8" opacity="0.9" />
								<rect x="155" y="275" width="4" height="4" fill="#F2E6D8" opacity="0.85" />
								<!-- chile slice -->
								<ellipse cx="270" cy="220" rx="12" ry="4" fill="#A8321E" opacity="0.95" />
								<ellipse cx="270" cy="220" rx="9" ry="2.5" fill="#6B2C19" opacity="0.9" />

								<!-- gloss highlight -->
								<ellipse cx="170" cy="220" rx="50" ry="10" fill="url(#brillo)" />
							</svg>
						</div>
						<div class="plato-label">
							<span class="plato-label-k">Plato estrella</span>
							<span class="plato-label-v">Chamorro en consomé</span>
						</div>
					</div>
				</aside>
			</div>
		</section>

		<!-- =========================================================
			HORARIOS — MUY VISIBLE (banner)
		========================================================== -->
		<section class="horarios-banner" id="horarios" aria-labelledby="horarios-heading">
			<div class="horarios-inner">
				<div class="horarios-left">
					<span class="horarios-label">Abrimos</span>
					<h2 id="horarios-heading" class="horarios-dias">{horarios.dias}</h2>
					<div class="horarios-horas">
						<span class="horarios-dot" aria-hidden="true"></span>
						{horarios.horas}
					</div>
				</div>
				<div class="horarios-right">
					<span class="horarios-cerrado-label">Descansamos</span>
					<span class="horarios-cerrado">{horarios.cerrado}</span>
				</div>
			</div>
		</section>

		<!-- =========================================================
			SOBRE
		========================================================== -->
		<section class="sobre" aria-labelledby="sobre-heading">
			<div class="sobre-inner">
				<span class="section-num">№ 01 · Concepto</span>
				<h2 id="sobre-heading" class="sobre-titulo">
					Aquí el chamorro <br />
					<em>no se acompaña.</em> <br />
					<em>Manda.</em>
				</h2>
				<p class="sobre-texto">
					Distrito Chamorro es un lugar donde el chamorro es el protagonista.
					Aquí se mezcla lo tradicional de Guadalajara con una ejecución urbana:
					<strong>consomé potente</strong>, <strong>tortillas recién hechas</strong>,
					<strong>barro de Tonalá</strong> y sabor sin pretensión.
				</p>
			</div>
		</section>

		<!-- =========================================================
			MENÚ
		========================================================== -->
		<section class="menu" id="menu" aria-labelledby="menu-heading">
			<div class="menu-head">
				<span class="section-num">№ 02 · La carta</span>
				<h2 id="menu-heading" class="menu-titulo">El menú</h2>
				<p class="menu-sub">Precios en pesos. Servicio no incluido.</p>
			</div>

			<!-- Plato estrella — card -->
			<article class="estrella" aria-label="Plato estrella">
				<div class="estrella-left">
					<span class="estrella-badge">★ Plato estrella</span>
					<h3 class="estrella-titulo">Chamorro entero<br />en consomé</h3>
					<p class="estrella-desc">
						Chamorro suave o dorado, 48 horas de marinado y ocho horas en
						caldo de la casa. Servido con:
					</p>
					<ul class="estrella-lista">
						{estrellaIncluye.map((x) => (
							<li>{x}</li>
						))}
					</ul>
				</div>
				<div class="estrella-right">
					<span class="estrella-precio">
						<span class="estrella-moneda">$</span>120
					</span>
					<span class="estrella-precio-alt">
						<span class="estrella-precio-alt-k">o medio por</span>
						<span class="estrella-precio-alt-v"><span class="estrella-precio-alt-moneda">$</span>80</span>
					</span>
					<a href="#lugar" class="estrella-cta">Vente por uno</a>
				</div>
			</article>

			<div class="menu-grid">
				<!-- TACOS -->
				<div class="menu-col">
					<h3 class="menu-col-titulo">Tacos</h3>
					<ul class="menu-col-list">
						{tacos.map((t) => (
							<li class="menu-col-item menu-col-item-rich">
								<div class="menu-col-line">
									<span class="menu-col-name">{t.name}</span>
									<span class="leader" aria-hidden="true"></span>
									<span class="precio">${t.price}</span>
								</div>
								<p class="menu-col-detail">{t.detail}</p>
							</li>
						))}
					</ul>
				</div>

				<!-- TORTAS -->
				<div class="menu-col">
					<h3 class="menu-col-titulo">Tortas</h3>
					<ul class="menu-col-list">
						{tortas.map((t) => (
							<li class="menu-col-item menu-col-item-rich">
								<div class="menu-col-line">
									<span class="menu-col-name">{t.name}</span>
									<span class="leader" aria-hidden="true"></span>
									<span class="precio">${t.price}</span>
								</div>
								<p class="menu-col-detail">{t.detail}</p>
							</li>
						))}
					</ul>
				</div>

				<!-- BEBIDAS -->
				<div class="menu-col">
					<h3 class="menu-col-titulo">Bebidas</h3>
					<ul class="menu-col-list">
						{bebidas.map((b) => (
							<li class="menu-col-item">
								<span>
									{b.name}
									{b.note && <span class="menu-nota"> · {b.note}</span>}
								</span>
								<span class="leader" aria-hidden="true"></span>
								<span class="precio">${b.price}</span>
							</li>
						))}
					</ul>
				</div>
			</div>

			<!-- COMBOS -->
			<div class="combos">
				<div class="combos-head">
					<span class="section-num combos-num">Combos · Para llevar o quedarse</span>
					<h3 class="combos-titulo">Pide todo junto</h3>
				</div>
				<div class="combos-grid">
					{combos.map((c, i) => (
						<article class="combo">
							<span class="combo-num">0{i + 1}</span>
							<h4 class="combo-nombre">{c.name}</h4>
							<p class="combo-incluye">{c.includes}</p>
							<span class="combo-precio">
								<span class="combo-moneda">$</span>{c.price}
							</span>
						</article>
					))}
				</div>
			</div>
		</section>

		{/* TODO: re-enable galería cuando tengamos fotos reales del local y los platos.
		<section class="galeria" aria-labelledby="galeria-heading">
			<div class="galeria-head">
				<span class="section-num">№ 03 · El barrio</span>
				<h2 id="galeria-heading" class="galeria-titulo">Así se ve el chamorro</h2>
			</div>
			<div class="galeria-grid">
				{galeria.map((g, i) => (
					<figure class={`foto foto-${i + 1}`} style={`--foto-hue: var(${g.hue});`}>
						<div class="foto-inner">
							<span class="foto-tag">{g.tag}</span>
							<span class="foto-label">{g.label}</span>
							<span class="foto-cruz" aria-hidden="true">
								<svg viewBox="0 0 24 24"><path d="M12 2v20M2 12h20" stroke="currentColor" stroke-width="1" /></svg>
							</span>
						</div>
					</figure>
				))}
			</div>
			<p class="galeria-nota">Fotos próximamente</p>
		</section>
		*/}

		<!-- =========================================================
			UBICACIÓN
		========================================================== -->
		<section class="lugar" id="lugar" aria-labelledby="lugar-heading">
			<div class="lugar-head">
				<span class="section-num">№ 03 · Ubicación</span>
				<h2 id="lugar-heading" class="lugar-titulo">Vente al distrito</h2>
			</div>

			<div class="lugar-grid">
				<div class="info-block info-direccion">
					<span class="info-label">Dirección</span>
					<p class="info-dir">
						<strong>{direccion.calle}</strong><br />
						{direccion.colonia}<br />
						{direccion.ciudad}
					</p>
					<a href={direccion.maps} class="info-cta" target="_blank" rel="noopener">
						Abrir en Google Maps
						<svg viewBox="0 0 20 20" aria-hidden="true" class="info-cta-arrow">
							<path d="M5 15 L15 5 M8 5 H15 V12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
						</svg>
					</a>
				</div>

				<a href={direccion.maps} class="lugar-mapa" target="_blank" rel="noopener" aria-label="Abrir ubicación en Google Maps">
					<!--
						Croquis de Jardines de la Cruz.
						Topología real:
						  - Isla Cozumel y Isla Trinidad son paralelas (corren NW-SE).
						  - Av. Fray Andrés de Urdaneta es perpendicular a las dos y
						    hace esquina con Isla Cozumel justo en la puerta del local.
						Rotación en (300, 200): el pin queda exactamente en la esquina
						Cozumel × Fray Andrés.
					-->
					<svg viewBox="0 0 600 400" class="mapa-svg" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
						<defs>
							<linearGradient id="mapa-wash" x1="0%" y1="0%" x2="100%" y2="100%">
								<stop offset="0%" stop-color="#F2E6D8" />
								<stop offset="100%" stop-color="#D9C8B2" />
							</linearGradient>
						</defs>

						<rect width="600" height="400" fill="url(#mapa-wash)" />

						<g transform="rotate(-40 300 200)">
							<!-- Manzanas (city blocks) generated to cover the rotated viewBox -->
							<g fill="#FAF3E8" stroke="#D9C8B2" stroke-width="1">
								{mapaBlocks.map((b) => (
									<rect x={b.x} y={b.y} width="90" height="90" rx="2" />
								))}
							</g>

							<!--
								Main streets:
								  - Isla Cozumel (horizontal in inner @ y=200) — restaurant street
								  - Isla Trinidad (horizontal in inner @ y=100) — parallel, above
								  - Av. Fray Andrés de Urdaneta (vertical in inner @ x=300) — esquina con Cozumel
							-->
							<g fill="#F2E6D8">
								<!-- Isla Cozumel -->
								<rect x="-200" y="193" width="1000" height="14" opacity="0.95" />
								<!-- Isla Trinidad — paralela a Cozumel -->
								<rect x="-200" y="93" width="1000" height="14" opacity="0.95" />
								<!-- Av. Fray Andrés de Urdaneta (main avenue, slightly wider) -->
								<rect x="292" y="-200" width="16" height="800" opacity="0.98" />
							</g>

							<!-- POI dots (nearby places) -->
							<g fill="#C9742A" opacity="0.65">
								{mapaPoi.map((p) => (
									<circle cx={p.x} cy={p.y} r="3.2" />
								))}
							</g>

							<!--
								Street labels riding on their street strokes. After the outer -40°
								rotation they follow the real diagonal direction of each street.
							-->
							<g font-family="Hanken Grotesk, sans-serif" font-weight="700" letter-spacing="3" fill="#8C3A21">
								<!-- ISLA COZUMEL — on the Cozumel strip (y~203), left of the pin -->
								<text x="40" y="203.5" font-size="11" opacity="0.9">ISLA · COZUMEL · 2670</text>
								<!-- ISLA TRINIDAD — on the parallel strip above (y~103) -->
								<text x="60" y="103.5" font-size="10" opacity="0.7">ISLA · TRINIDAD</text>
								<!--
									AV. FRAY ANDRÉS — perpendicular avenue, vertical in inner coords.
									Shortened so it fits in the visible strip between the pin and the
									Google Maps CTA at the bottom-right.
								-->
								<text x="302" y="250" font-size="9" opacity="0.7" transform="rotate(90 302 250)">AV. FRAY ANDRÉS</text>
							</g>

							<!-- Esquina marker — subtle dot at the exact corner -->
							<circle cx="300" cy="200" r="3" fill="#8C3A21" opacity="0.35" />
						</g>

						<!-- Radial glow under pin (al este de la esquina, sobre Isla Cozumel) -->
						<circle cx="331" cy="174" r="56" fill="#A8321E" opacity="0.11" />
						<circle cx="331" cy="174" r="28" fill="#A8321E" opacity="0.2" />

						<!--
							Pin — drawn inside the main SVG so it shares coordinates with
							the glow. Outer <g> places the tip at (331, 174) in viewBox
							coords; inner .mapa-pin-g only handles the bounce animation.
						-->
						<g transform="translate(311 122)">
							<g class="mapa-pin-g">
